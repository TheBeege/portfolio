---
interface Props {
  title: string;
  company?: string;
  roles?: string[];
  tags: string[];
  links?: { label: string; url: string }[];
  images?: { src: string; alt: string }[];
  highlight?: string;
  teamSize?: string;
  companyContext?: string;
}

const { title, company, roles, tags, links, images, highlight, teamSize, companyContext } = Astro.props;
---

<div class="bg-surface-light rounded-xl p-8 border border-white/10">
  <!-- Header -->
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
    <h3 class="text-2xl font-semibold">{title}</h3>
    {(company || roles || teamSize || companyContext) && (
      <div class="flex flex-col items-start md:items-end gap-1 text-sm text-text-muted shrink-0">
        {company && <span>{company}</span>}
        {companyContext && <span class="text-xs italic">{companyContext}</span>}
        {roles && <span>{roles.join(" / ")}</span>}
        {teamSize && <span>Team: {teamSize}</span>}
      </div>
    )}
  </div>

  <!-- Links -->
  {links && links.length > 0 && (
    <div class="flex gap-3 text-sm text-text-muted mb-4">
      {links.map((link) => (
        <a href={link.url} target="_blank" class="hover:text-primary transition-colors">{link.label} ↗</a>
      ))}
    </div>
  )}

  <!-- Description (slot) -->
  <div class="text-text-muted mb-6">
    <slot />
  </div>

  <!-- Highlight -->
  {highlight && (
    <blockquote class="border-l-4 border-primary bg-primary/10 rounded-r-lg px-4 py-3 mb-6 text-text-muted italic">
      {highlight}
    </blockquote>
  )}

  <!-- Images -->
  {images && images.length > 0 && (
    <div class="grid md:grid-cols-3 gap-4 mb-6">
      {images.map((img) => (
        <img src={img.src} alt={img.alt} class="rounded-lg border border-white/10 w-full" />
      ))}
    </div>
  )}

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">{tag}</span>
    ))}
  </div>
</div>
