          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Spring Boot</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Maven</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">BitBucket</span>
        </div>
