---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
---

<Layout title="Beege's Portfolio">
  <!-- Hero -->
  <div class="min-h-[70vh] flex items-center">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-primary font-mono mb-4">Hi, I'm</p>
      <h1 class="text-5xl md:text-7xl font-bold mb-4">Beege!</h1>
      <p class="text-primary font-mono mb-4">Or Bryan Berry if you want to be boring and legal</p>
      <p class="text-xl md:text-2xl text-text-muted max-w-2xl mb-8">
        Engineering leader, builder, and community organizer based in Seoul.
      </p>
      <div class="flex gap-4">
        <a href="#contact" class="bg-primary hover:bg-primary-dark px-6 py-3 rounded-lg font-medium transition-colors">
          Get in touch
        </a>
        <a href="#personal-projects" class="border border-white/20 hover:border-white/40 px-6 py-3 rounded-lg font-medium transition-colors">
          See my work
        </a>
      </div>
    </div>
  </div>

  <!-- Personal Projects -->
  <Section id="personal-projects" title="Personal Projects">
    <div class="space-y-16">

      <!-- VizPlan -->
      <div class="bg-surface-light rounded-xl p-8 border border-white/10">
        <div class="flex items-start justify-between mb-4">
          <h3 class="text-2xl font-semibold">VizPlan</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <a href="https://vizplan.app" target="_blank" class="hover:text-primary transition-colors">Live ↗</a>
          </div>
        </div>
        <p class="text-text-muted mb-6">
          A SaaS tool for engineering leaders to visualize alignment between company goals and the work teams are actually doing. Connects to project management tools (Jira, Linear, etc.) and surfaces where planned work drifts from strategic objectives — giving leaders real visibility without micromanaging. Designed with a bidirectional sync strategy to meet teams where they already work.
        </p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <img src="/vizplan1.png" alt="VizPlan landing page showing 'Plan Your Work From Vision to Action' headline with an isometric node visualization" class="rounded-lg border border-white/10 w-full" />
          <img src="/vizplan2.png" alt="VizPlan hierarchical tree view with nested task cards showing priority levels and roll-up progress" class="rounded-lg border border-white/10 w-full" />
          <img src="/vizplan3.png" alt="VizPlan team settings page showing member management and API key configuration" class="rounded-lg border border-white/10 w-full" />
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Next.js</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">TypeScript</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Supabase</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SaaS</span>
        </div>
      </div>

      <!-- MedDaaS -->
      <div class="bg-surface-light rounded-xl p-8 border border-white/10">
        <div class="flex items-start justify-between mb-4">
          <h3 class="text-2xl font-semibold">MedDaaS</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <a href="https://meddaas.beege.works" target="_blank" class="hover:text-primary transition-colors">Live ↗</a>
            <a href="https://github.com/CodeSeoul/MedDaaS" target="_blank" class="hover:text-primary transition-colors">GitHub ↗</a>
          </div>
        </div>
        <p class="text-text-muted mb-6">
          An AI-powered radiology training platform that helps medical students and radiologists sharpen their diagnostic skills. Students write diagnostic reports for chest X-rays, and the system compares them against expert ground truth using multi-step LLM analysis — delivering finding-by-finding scoring, educational feedback, and actionable improvement suggestions in real time via streaming. Built for the Spoon OS hackathon with CodeSeoul.
        </p>
        <div class="grid md:grid-cols-3 gap-4 mb-6">
          <img src="/meddaas1.png" alt="MedDaaS homepage with search bar and progress card showing a score of 62.9/100 with 2 reports completed" class="rounded-lg border border-white/10 w-full" />
          <img src="/meddaas2.png" alt="MedDaaS reporting interface showing a chest X-ray with brightness and contrast controls alongside a report text editor" class="rounded-lg border border-white/10 w-full" />
          <img src="/medaas3.png" alt="MedDaaS detailed feedback page with scoring breakdown for similarity, completeness, accuracy, and terminology, plus finding-by-finding analysis" class="rounded-lg border border-white/10 w-full" />
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">FastAPI</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Python</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">LLM / RAG</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">FAISS</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">PostgreSQL</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SSE Streaming</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SpoonAI SDK</span>
        </div>
      </div>

      <!-- Model Server -->
      <div class="bg-surface-light rounded-xl p-8 border border-white/10">
        <div class="flex items-start justify-between mb-4">
          <h3 class="text-2xl font-semibold">Model Server</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <!-- TODO: add GitHub link once repo is public -->
          </div>
        </div>
        <p class="text-text-muted mb-6">
          A self-hosted LLM inference server for running open-weight models locally. Built to support a medical device AI application — providing diagnostic assistance for field and service maintenance of imaging devices (starting with ultrasound). Designed to run models like Qwen on local infrastructure, avoiding vendor lock-in and VPN dependencies.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Python</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">LLM Inference</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Qwen</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Medical AI</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Self-Hosted</span>
        </div>
      </div>

    </div>
  </Section>

  <!-- Professional Experience -->
  <Section id="professional-projects" title="Professional Experience">
    <div class="space-y-8">
      <div class="border-l-2 border-primary pl-6">
        <h3 class="text-xl font-semibold">Role Title</h3>
        <p class="text-primary text-sm">Company — 2024–Present</p>
        <p class="text-text-muted mt-2">Description placeholder.</p>
      </div>
    </div>
  </Section>

  <!-- About -->
  <Section id="about" title="About">
    <div class="text-text-muted text-lg leading-relaxed max-w-3xl space-y-4">
      <p>Placeholder — your story goes here.</p>
    </div>
  </Section>

  <!-- Community -->
  <Section id="community" title="Community">
    <div class="text-text-muted text-lg leading-relaxed max-w-3xl space-y-4">
      <p>Placeholder — CodeSeoul, mentoring, events.</p>
    </div>
  </Section>

  <!-- Contact -->
  <Section id="contact" title="Get in Touch">
    <div class="max-w-xl">
      <p class="text-text-muted text-lg mb-8">Placeholder — links and contact info.</p>
      <div class="flex gap-4">
        <a href="https://github.com/TheBeege" target="_blank" class="text-text-muted hover:text-text transition-colors">GitHub</a>
        <a href="https://linkedin.com/in/" target="_blank" class="text-text-muted hover:text-text transition-colors">LinkedIn</a>
      </div>
    </div>
  </Section>
</Layout>
