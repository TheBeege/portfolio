---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
---

<Layout title="Beege's Portfolio">
  <!-- Hero -->
  <div class="min-h-[70vh] flex items-center">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-primary font-mono mb-4">Hi, I'm</p>
      <h1 class="text-5xl md:text-7xl font-bold mb-4">Beege!</h1>
      <p class="text-primary font-mono mb-4">Or Bryan Berry if you want to be boring and legal</p>
      <p class="text-xl md:text-2xl text-text-muted max-w-2xl mb-8">
        Engineering leader, builder, and community organizer based in Seoul.
      </p>
      <div class="flex gap-4">
        <a href="#contact" class="bg-primary hover:bg-primary-dark px-6 py-3 rounded-lg font-medium transition-colors">
          Get in touch
        </a>
        <a href="#projects" class="border border-white/20 hover:border-white/40 px-6 py-3 rounded-lg font-medium transition-colors">
          See my work
        </a>
      </div>
    </div>
  </div>

  <!-- Projects -->
  <Section id="projects" title="Projects">
    <div class="grid md:grid-cols-2 gap-8">

      <!-- MedDaaS -->
      <div class="bg-surface-light rounded-xl p-6 border border-white/10 hover:border-primary/50 transition-colors md:col-span-2">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold">MedDaaS</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <a href="https://meddaas.beege.works" target="_blank" class="hover:text-primary transition-colors">Live ↗</a>
            <a href="https://github.com/CodeSeoul/MedDaaS" target="_blank" class="hover:text-primary transition-colors">GitHub ↗</a>
          </div>
        </div>
        <p class="text-text-muted mb-4">
          An AI-powered radiology training platform that helps medical students and radiologists sharpen their diagnostic skills. Students write diagnostic reports for chest X-rays, and the system compares them against expert ground truth using multi-step LLM analysis — delivering finding-by-finding scoring, educational feedback, and actionable improvement suggestions in real time via streaming.
        </p>
        <p class="text-text-muted mb-4">
          Built for the Spoon OS hackathon with CodeSeoul. Uses a graph-based LLM workflow (SpoonAI SDK) to orchestrate comparison, with FAISS-powered semantic search for RAG-based image retrieval and a multi-dimensional scoring system covering similarity, completeness, accuracy, and medical terminology.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">FastAPI</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Python</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">LLM / RAG</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">FAISS</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">PostgreSQL</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SSE Streaming</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SpoonAI SDK</span>
        </div>
      </div>

      <!-- VizPlan -->
      <div class="bg-surface-light rounded-xl p-6 border border-white/10 hover:border-primary/50 transition-colors">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold">VizPlan</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <a href="https://vizplan.app" target="_blank" class="hover:text-primary transition-colors">Live ↗</a>
          </div>
        </div>
        <p class="text-text-muted mb-4">
          A SaaS tool for engineering leaders to visualize alignment between company goals and the work teams are actually doing. Connects to project management tools (Jira, Linear, etc.) and surfaces where planned work drifts from strategic objectives — giving leaders real visibility without micromanaging.
        </p>
        <p class="text-text-muted mb-4">
          Built as part of Hapsen, the company I co-founded. Designed with a bidirectional sync strategy to meet teams where they already work. Currently in the problem validation and early prototype stage.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Next.js</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">TypeScript</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Supabase</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">SaaS</span>
        </div>
      </div>

      <!-- model_server -->
      <div class="bg-surface-light rounded-xl p-6 border border-white/10 hover:border-primary/50 transition-colors">
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-xl font-semibold">Model Server</h3>
          <div class="flex gap-3 text-sm text-text-muted">
            <!-- TODO: add GitHub link once repo is public -->
          </div>
        </div>
        <p class="text-text-muted mb-4">
          A self-hosted LLM inference server for running open-weight models locally. Built to support a medical device AI application — providing diagnostic assistance for field/service maintenance of imaging devices (starting with ultrasound).
        </p>
        <p class="text-text-muted mb-4">
          Designed to run models like Qwen on local infrastructure, avoiding vendor lock-in and VPN dependencies. Part of a co-venture focused on bringing AI-assisted diagnostics to all imaging device types.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Python</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">LLM Inference</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Qwen</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Medical AI</span>
          <span class="text-xs bg-primary/20 text-primary px-2 py-1 rounded">Self-Hosted</span>
        </div>
      </div>

    </div>
  </Section>

  <!-- About -->
  <Section id="about" title="About">
    <div class="text-text-muted text-lg leading-relaxed max-w-3xl space-y-4">
      <p>Placeholder — your story goes here.</p>
    </div>
  </Section>

  <!-- Experience -->
  <Section id="experience" title="Experience">
    <div class="space-y-8">
      <div class="border-l-2 border-primary pl-6">
        <h3 class="text-xl font-semibold">Role Title</h3>
        <p class="text-primary text-sm">Company — 2024–Present</p>
        <p class="text-text-muted mt-2">Description placeholder.</p>
      </div>
    </div>
  </Section>

  <!-- Community -->
  <Section id="community" title="Community">
    <div class="text-text-muted text-lg leading-relaxed max-w-3xl space-y-4">
      <p>Placeholder — CodeSeoul, mentoring, events.</p>
    </div>
  </Section>

  <!-- Contact -->
  <Section id="contact" title="Get in Touch">
    <div class="max-w-xl">
      <p class="text-text-muted text-lg mb-8">Placeholder — links and contact info.</p>
      <div class="flex gap-4">
        <a href="https://github.com/TheBeege" target="_blank" class="text-text-muted hover:text-text transition-colors">GitHub</a>
        <a href="https://linkedin.com/in/" target="_blank" class="text-text-muted hover:text-text transition-colors">LinkedIn</a>
      </div>
    </div>
  </Section>
</Layout>
