---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Bryan Berry — Engineering Leader, Builder, Community Organizer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-text min-h-screen antialiased">
    <nav class="fixed top-0 w-full bg-surface/80 backdrop-blur-md border-b border-white/10 z-50">
      <div class="max-w-5xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-lg font-bold hover:text-primary transition-colors">BB</a>
        <div class="flex gap-6 text-sm text-text-muted">
          <a href="#about" class="hover:text-text transition-colors">About</a>
          <a href="#experience" class="hover:text-text transition-colors">Experience</a>
          <a href="#projects" class="hover:text-text transition-colors">Projects</a>
          <a href="#community" class="hover:text-text transition-colors">Community</a>
          <a href="#contact" class="hover:text-text transition-colors">Contact</a>
        </div>
      </div>
    </nav>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="border-t border-white/10 py-8 text-center text-text-muted text-sm">
      <div class="max-w-5xl mx-auto px-6">
        © {new Date().getFullYear()} Bryan Berry
      </div>
    </footer>
  </body>
</html>
